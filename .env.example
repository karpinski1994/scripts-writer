# Scripts Writer - Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider: Modal (GLM-5.1)
MODAL_API_KEY=
MODAL_BASE_URL=https://api.us-west-2.modal.direct/v1

# LLM Provider: Groq
GROQ_API_KEY=

# LLM Provider: Google Gemini
GEMINI_API_KEY=

# LLM Provider: Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/scripts_writer.db

# Export directory for generated files
EXPORT_DIR=./data/exports

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# LLM Response Cache
CACHE_MAX_SIZE=128
CACHE_TTL_SECONDS=3600

# Retry configuration for LLM providers
MAX_RETRIES=3

# Frontend editor auto-save debounce (milliseconds)
DEBOUNCE_SAVE_MS=500
